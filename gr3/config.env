# ========== 相机 ==========

# 相机的旋转角度
DAQ_CAMERA_ROTATE=180

# 相机图像上的时间戳
DAQ_DRAW_TIMESTAMP=0

# ========== 头显 ==========

# 手指和手臂的长度映射
# 一般和身高正相关，范围0.8~1.3左右
# GR2 默认值 1.2 1.25
# GR3 默认值 1.3 1.1
# RETARGETING_HAND_SCALING=1.2
# RETARGETING_BODY_SCALING=1.25

# ========== 脚舵 ==========

# 脚舵的型号
PEDAL_NAME=T-Rudder

# ========== 外骨骼 ==========

# 长按短按时间
QNEXO_SHORT_PRESS_MAX_DELAY=0.5
QNEXO_LONG_PRESS_MIN_TIME=3

# 摇杆数据范围
QNEXO_JOYSTICK_MIN=500
QNEXO_JOYSTICK_MAX=3900
QNEXO_JOYSTICK_CENTER=2048
QNEXO_JOYSTICK_DEADZONE=200

# 扳机数据范围
# 松开
QNEXO_TRIGGER_MIN=700
# 夹紧
QNEXO_TRIGGER_MAX=3700

# 机器人抓手位置控制参数-开
EXO_GRIPPER_OPEN_POS_0=0.0
EXO_GRIPPER_OPEN_POS_1=0.0
EXO_GRIPPER_OPEN_POS_2=0.0
EXO_GRIPPER_OPEN_POS_3=0.0
EXO_GRIPPER_OPEN_POS_4=0.0
EXO_GRIPPER_OPEN_POS_5=-1.57

# 机器人抓手位置控制参数-合
EXO_GRIPPER_CLOSED_POS_0=-2.0
EXO_GRIPPER_CLOSED_POS_1=-2.0
EXO_GRIPPER_CLOSED_POS_2=-2.0
EXO_GRIPPER_CLOSED_POS_3=-2.0
EXO_GRIPPER_CLOSED_POS_4=1.0
EXO_GRIPPER_CLOSED_POS_5=-1.57

# 头部和腰部关节速度控制参数
# 头部俯仰速度，默认 0.1/s at 100Hz
EXO_HEAD_PITCH_SPEED=0.1
# 腰部偏航速度，默认 0.1/s at 100Hz
EXO_WAIST_YAW_SPEED=0.1
# 腰部俯仰速度，默认 0.1/s at 100Hz
EXO_WAIST_PITCH_SPEED=0.1

# 基础运动控制参数
# X方向速度系数
EXO_BASE_VEL_X_COEF=0.8
# Y方向速度系数
EXO_BASE_VEL_Y_COEF=0.8
# 偏航角速度系数
EXO_BASE_VEL_YAW_COEF=0.8
# 高度速度系数
EXO_BASE_VEL_HEIGHT_COEF=0.15

# IMU 控制开关
USE_IMU_WAIST_PITCH=0

# 断链后最大继续发送消息的时间
EXO_MAX_RAW_DATA_DELAY=1.1
