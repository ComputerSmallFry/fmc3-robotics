# 默认注释了源码镜像以提高 apt update 速度，如有需要可自行取消注释
deb http://nexus.fftaicorp.com/repository/apt-proxy-jammy/ jammy main restricted universe multiverse
# deb-src http://nexus.fftaicorp.com/repository/apt-proxy-jammy/ jammy main restricted universe multiverse
deb http://nexus.fftaicorp.com/repository/apt-proxy-jammy/ jammy-updates main restricted universe multiverse
# deb-src http://nexus.fftaicorp.com/repository/apt-proxy-jammy/ jammy-updates main restricted universe multiverse
deb http://nexus.fftaicorp.com/repository/apt-proxy-jammy/ jammy-backports main restricted universe multiverse
# deb-src http://nexus.fftaicorp.com/repository/apt-proxy-jammy/ jammy-backports main restricted universe multiverse

# 以下安全更新软件源包含了官方源与镜像站配置，如有需要可自行修改注释切换
deb http://nexus.fftaicorp.com/repository/apt-proxy-jammy/ jammy-security main restricted universe multiverse
# deb-src http://nexus.fftaicorp.com/repository/apt-proxy-jammy/ jammy-security main restricted universe multiverse

# 预发布软件源，不建议启用
# deb http://nexus.fftaicorp.com/repository/apt-proxy-jammy/ jammy-proposed main restricted universe multiverse
# deb-src http://nexus.fftaicorp.com/repository/apt-proxy-jammy/ jammy-proposed main restricted universe multiverse
